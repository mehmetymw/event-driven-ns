APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://notification_user:notification_pass@localhost:5432/notification_db?sslmode=disable

KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=notification-worker

